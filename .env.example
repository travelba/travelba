# Travel Business Agency — variables d'environnement

# Clé API Resend (https://resend.com) pour l'envoi des emails du formulaire de contact.
# Sans cette clé, le formulaire fonctionne mais les demandes sont seulement loggées côté serveur.
RESEND_API_KEY=

# Adresse expéditrice vérifiée sur Resend (ex: contact@votre-domaine.com).
# Par défaut: onboarding@resend.dev (utilisable uniquement pour les tests).
CONTACT_FROM_EMAIL=

# Adresse qui reçoit les demandes du formulaire (par défaut: valeur de lib/site.ts).
CONTACT_TO_EMAIL=
